---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PostCard from '../components/PostCard.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);

const posts = (await getCollection('writing'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Summed from each project's own suite — never hand-maintained.
const totalTests = projects.reduce((sum, p) => sum + (p.data.tests ?? 0), 0);

// Bento spans for the home grid, keyed by slug. Anything new defaults to
// a half-width card until it earns a slot.
const spans: Record<string, string> = {
  redcell: 'md:col-span-7',
  longhaul: 'md:col-span-5',
  patchbay: 'md:col-span-5',
  millstone: 'md:col-span-7',
  callcheck: 'md:col-span-4',
  'eval-gate': 'md:col-span-8',
};

const contact = [
  { label: 'email', value: 'latinosammy2@gmail.com', href: 'mailto:latinosammy2@gmail.com' },
  { label: 'github', value: 'github.com/slatino-dev', href: 'https://github.com/slatino-dev' },
  { label: 'linkedin', value: 'linkedin.com/in/samlatino', href: 'https://www.linkedin.com/in/samlatino' },
  { label: 'hf', value: 'huggingface.co/SamLatino', href: 'https://huggingface.co/SamLatino' },
];
---

<BaseLayout title="Sam Latino — AI engineer">
  <section class="mx-auto max-w-5xl px-5 pt-16 pb-12 md:pt-24">
    <p class="prompt m-0 text-xs">
      <span class="prompt-user">sam@latino</span><span class="prompt-sep"
        >:</span
      ><span class="prompt-path">~</span><span class="prompt-sigil">$</span>
      <span class="text-text-muted">whoami</span>
    </p>
    <h1 class="mt-5 mb-0 max-w-[36ch] text-2xl/snug font-semibold md:text-3xl/snug">
      AI engineer. Agent systems, evals, and self-hosted LLM infrastructure —
      Rust&nbsp;+&nbsp;Python.<span class="cursor" aria-hidden="true"></span>
    </h1>
    <p class="mt-8 mb-0 font-mono text-[0.8125rem] text-text-muted">
      {projects.length} open-source projects
      <span class="text-text-faint">&nbsp;&middot;&nbsp;</span>
      {totalTests} tests
      <span class="text-text-faint">&nbsp;&middot;&nbsp;</span>
      Rust
      <span class="text-text-faint">&middot;</span>
      Python
      <span class="text-text-faint">&middot;</span>
      TypeScript
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-5 pb-12" aria-labelledby="projects-heading">
    <div class="flex items-baseline justify-between border-b border-border pb-2">
      <h2 id="projects-heading" class="m-0 text-sm font-medium text-text-muted">
        ~/projects
      </h2>
      <span class="font-mono text-xs text-text-faint">{projects.length} dirs</span>
    </div>

    <ul class="mt-5 grid list-none grid-cols-1 gap-3 p-0 md:grid-cols-12">
      {
        projects.map((project) => (
          <li class={`grid ${spans[project.data.slug] ?? 'md:col-span-6'}`}>
            <ProjectCard project={project} />
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mx-auto max-w-5xl px-5 pb-12" aria-labelledby="writing-heading">
    <div class="flex items-baseline justify-between border-b border-border pb-2">
      <h2 id="writing-heading" class="m-0 text-sm font-medium text-text-muted">
        ~/writing
      </h2>
      <a class="font-mono text-xs text-text-faint no-underline hover:text-accent" href="/rss.xml">rss</a>
    </div>

    {
      posts.length > 0 ? (
        <div class="mt-2">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      ) : (
        <p class="mt-5 mb-0 font-mono text-[0.8125rem] text-text-muted">
          <span class="text-text-faint">$ ls ~/writing</span>
          <br />
          empty — first posts are being drafted alongside the case studies.
          The <a href="/rss.xml">feed</a> is already live.
        </p>
      )
    }
  </section>

  <section class="mx-auto max-w-5xl px-5 pb-8" aria-labelledby="contact-heading">
    <div class="flex items-baseline justify-between border-b border-border pb-2">
      <h2 id="contact-heading" class="m-0 text-sm font-medium text-text-muted">
        ~/contact
      </h2>
    </div>

    <dl class="mt-5 mb-0 grid max-w-md grid-cols-[auto_1fr] gap-x-8 gap-y-1.5 font-mono text-[0.8125rem]">
      {
        contact.map((c) => (
          <>
            <dt class="m-0 text-text-faint">{c.label}</dt>
            <dd class="m-0">
              <a class="no-underline hover:text-accent" rel="me" href={c.href}>
                {c.value}
              </a>
            </dd>
          </>
        ))
      }
    </dl>
  </section>
</BaseLayout>
