---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Project {
  name: string;
  desc: string;
  lang: string;
  span: string;
}

// Placeholder cards — real pages land with the projects themselves.
const projects: Project[] = [
  {
    name: 'redcell',
    desc: 'Adversarial scenario runner for red-teaming agent systems.',
    lang: 'rust',
    span: 'md:col-span-7',
  },
  {
    name: 'longhaul',
    desc: 'Soak-tests agents over long horizons to find where they drift.',
    lang: 'python',
    span: 'md:col-span-5',
  },
  {
    name: 'patchbay',
    desc: 'Routing and failover layer for self-hosted model inference.',
    lang: 'rust',
    span: 'md:col-span-5',
  },
  {
    name: 'millstone',
    desc: 'Grinds raw transcripts and traces into eval datasets.',
    lang: 'python',
    span: 'md:col-span-7',
  },
  {
    name: 'callcheck',
    desc: 'Conformance checks for tool-calling across model backends.',
    lang: 'rust',
    span: 'md:col-span-4',
  },
  {
    name: 'eval-gate',
    desc: 'CI gate that blocks merges on eval regressions, not vibes.',
    lang: 'python',
    span: 'md:col-span-8',
  },
];
---

<BaseLayout title="Sam Latino — AI engineer">
  <section class="mx-auto max-w-5xl px-5 pt-16 pb-12 md:pt-24">
    <p class="prompt m-0 text-xs">
      <span class="prompt-user">sam@latino</span><span class="prompt-sep"
        >:</span
      ><span class="prompt-path">~</span><span class="prompt-sigil">$</span>
      <span class="text-text-muted">whoami</span>
    </p>
    <h1 class="mt-5 mb-0 max-w-[36ch] text-2xl/snug font-semibold md:text-3xl/snug">
      AI engineer. Agent systems, evals, and self-hosted LLM infrastructure —
      Rust&nbsp;+&nbsp;Python.<span class="cursor" aria-hidden="true"></span>
    </h1>
    <p
      class="mt-8 mb-0 flex flex-wrap gap-x-7 gap-y-1.5 font-mono text-[0.8125rem] text-text-muted"
    >
      <span><span class="text-text-faint">projects&nbsp;</span>6</span>
      <span
        ><span class="text-text-faint">langs&nbsp;</span>rust&nbsp;&middot;&nbsp;python</span
      >
      <span><span class="text-text-faint">inference&nbsp;</span>self-hosted</span>
      <span
        ><span class="text-text-faint">status&nbsp;</span>everything below is
        pre-1.0</span
      >
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-5 pb-8" aria-labelledby="projects-heading">
    <div class="flex items-baseline justify-between border-b border-border pb-2">
      <h2
        id="projects-heading"
        class="m-0 text-sm font-medium text-text-muted"
      >
        ~/projects
      </h2>
      <span class="font-mono text-xs text-text-faint">6 dirs</span>
    </div>

    <ul class="mt-5 grid list-none grid-cols-1 gap-3 p-0 md:grid-cols-12">
      {
        projects.map((p) => (
          <li class={`term-frame term-frame-link ${p.span}`}>
            <div class="term-bar">
              ~/projects/{p.name}
              <span class="term-bar-meta">{p.lang}</span>
            </div>
            <div class="term-body">
              <h3 class="m-0 text-base font-semibold">
                <a
                  class="no-underline hover:text-accent"
                  href={`/projects/${p.name}/`}
                >
                  {p.name}
                </a>
              </h3>
              <p class="mt-1.5 mb-0 text-sm text-text-muted">{p.desc}</p>
              <p class="mt-3.5 mb-0 font-mono text-xs text-text-faint">
                status: scaffolding
              </p>
            </div>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
