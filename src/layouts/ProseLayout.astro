---
/**
 * ProseLayout — renders a `writing` collection entry: dateline, title,
 * description, tags, then the MDX body with the component kit injected.
 */
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { mdxKit } from '../components/mdx-kit';

interface Props {
  entry: CollectionEntry<'writing'>;
}

const { entry } = Astro.props;
const { slug, title, date, description, tags } = entry.data;

const { Content } = await render(entry);
const isoDate = date.toISOString().slice(0, 10);
---

<BaseLayout title={`${title} — Sam Latino`} description={description}>
  <article class="mx-auto max-w-5xl px-5 pt-12 pb-8 md:pt-16">
    <header>
      <p class="prompt m-0 text-xs">
        <span class="prompt-user">sam@latino</span><span class="prompt-sep"
          >:</span
        ><span class="prompt-path">~/writing</span><span class="prompt-sigil"
          >$</span
        >
        <span class="text-text-muted">cat {slug}.md</span>
      </p>

      <p class="mt-5 mb-0 font-mono text-xs text-text-faint">
        <time datetime={isoDate}>{isoDate}</time>
        {tags.length > 0 && <span> &middot; {tags.join(' · ')}</span>}
      </p>
      <h1 class="mt-2 mb-0 text-2xl font-semibold md:text-3xl">{title}</h1>
      <p class="mt-3 mb-0 max-w-[64ch] text-base text-text-muted">
        {description}
      </p>
    </header>

    <hr class="my-8" />

    <div class="prose">
      <Content components={mdxKit} />
    </div>
  </article>
</BaseLayout>
