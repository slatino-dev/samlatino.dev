---
/**
 * DeadEnd — "what broke / what I'd do differently." The honest counterpart
 * to DecisionNote. Deliberately neutral in color: the regression hue is
 * reserved for benchmark table cells, and a dead end documented is not a
 * regression — it's the work.
 */
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<aside class="dead-end" aria-label={`Dead end: ${title}`}>
  <p class="label">
    <span class="marker" aria-hidden="true">##</span> dead end &mdash; {title}
  </p>
  <div class="body">
    <slot />
  </div>
</aside>

<style>
  .dead-end {
    margin: 1.75rem 0;
    border: 1px dashed var(--color-border-strong);
    border-radius: var(--radius-md);
    background-color: transparent;
    padding: 0.875rem 1rem;
  }

  .label {
    margin: 0 0 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
  }

  .marker {
    color: var(--color-text-faint);
  }

  .body {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .body :global(p) {
    margin: 0 0 0.65rem;
  }

  .body :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
