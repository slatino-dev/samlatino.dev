---
/**
 * ArchDiagram — terminal-framed figure for an inline SVG architecture
 * diagram. The SVG goes in the slot (inline, so it inherits CSS variables
 * and stays crawlable text); `caption` becomes the figcaption.
 */
interface Props {
  /** term-bar label, e.g. "docs/architecture.svg". */
  path?: string;
  caption: string;
}

const { path = 'docs/architecture.svg', caption } = Astro.props;
---

<figure class="term-frame arch">
  <div class="term-bar">{path}</div>
  <div class="diagram" role="img" aria-label={caption}>
    <slot />
  </div>
  <figcaption>{caption}</figcaption>
</figure>

<style>
  .arch {
    margin: 1.75rem 0;
  }

  .diagram {
    padding: 1.25rem 1rem;
    overflow-x: auto;
  }

  .diagram :global(svg) {
    display: block;
    margin-inline: auto;
    max-width: 100%;
    height: auto;
    font-family: var(--font-mono);
  }

  /* Shared diagram vocabulary. The case-study SVGs are hand-authored inline
     and use these classes, so every diagram draws from the same hairline +
     single-accent palette as the rest of the site. */
  .diagram :global(.box) {
    fill: var(--color-surface-2);
    stroke: var(--color-border-strong);
    stroke-width: 1;
  }

  .diagram :global(.box-accent) {
    stroke: var(--color-accent-dim);
  }

  .diagram :global(.box-ghost) {
    fill: transparent;
    stroke: var(--color-border-strong);
    stroke-dasharray: 4 3;
  }

  .diagram :global(.lbl) {
    fill: var(--color-text);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .diagram :global(.lbl-accent) {
    fill: var(--color-accent);
  }

  .diagram :global(.sub) {
    fill: var(--color-text-muted);
    font-size: 9.5px;
  }

  .diagram :global(.note) {
    fill: var(--color-text-faint);
    font-size: 9.5px;
    letter-spacing: 0.02em;
  }

  .diagram :global(.edge) {
    fill: none;
    stroke: var(--color-border-strong);
    stroke-width: 1;
  }

  .diagram :global(.edge-accent) {
    stroke: var(--color-accent-dim);
  }

  .diagram :global(.edge-dashed) {
    stroke-dasharray: 4 3;
  }

  .diagram :global(.arrow) {
    fill: var(--color-border-strong);
  }

  .diagram :global(.arrow-accent) {
    fill: var(--color-accent-dim);
  }

  figcaption {
    padding: 0.5rem 0.75rem;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.02em;
    color: var(--color-text-faint);
  }
</style>
