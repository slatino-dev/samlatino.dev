---
/**
 * ProjectCard — one project in the home/listing grid. Reads everything from
 * a `projects` collection entry; the only layout knob is `class` (grid span).
 */
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  class?: string;
}

const { project, class: className = '' } = Astro.props;
const { slug, title, tagline, language, status, tests } = project.data;
---

<article class={`term-frame term-frame-link ${className}`}>
  <div class="term-bar">
    ~/projects/{slug}
    <span class="term-bar-meta">{language.toLowerCase()}</span>
  </div>
  <div class="term-body">
    <h3 class="m-0 text-base font-semibold">
      <a class="no-underline hover:text-accent" href={`/projects/${slug}/`}>
        {title}
      </a>
    </h3>
    <p class="mt-1.5 mb-0 text-sm text-text-muted">{tagline}</p>
    <p class="mt-3.5 mb-0 font-mono text-xs text-text-faint">
      <span>status: {status}</span>
      {tests && <span> &middot; {tests} tests</span>}
    </p>
  </div>
</article>
