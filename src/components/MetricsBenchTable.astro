---
/**
 * MetricsBenchTable — reads src/data/metrics/<slug>.json when present and
 * renders each table entry through BenchTable. Falls through to BenchTable's
 * own empty-state if the metrics file does not exist yet.
 *
 * Usage in MDX:
 *   <MetricsBenchTable slug="redcell" tableId="hardening-sweep" />
 *
 * When src/data/metrics/redcell.json exists and contains a table with
 * id="hardening-sweep", it renders the live data. When the file is absent
 * or the table id is not found, it renders the "benchmarks in progress" state.
 *
 * This component powers the Phase E metric-sync flow: once
 * scripts/sync-metrics.mjs writes the JSON, the site auto-updates on next
 * build with zero MDX edits.
 */
import BenchTable from './BenchTable.astro';
import type { BenchColumn, BenchCell } from './BenchTable.astro';

interface MetricsColumn {
  key: string;
  label: string;
  numeric?: boolean;
  delta?: 'good' | 'bad' | null;
}

interface MetricsRow {
  [key: string]: string | number;
}

interface MetricsTable {
  id: string;
  caption?: string;
  columns: MetricsColumn[];
  rows: MetricsRow[];
}

interface MetricsFile {
  version: string;
  generated: string;
  tables: MetricsTable[];
  _meta?: {
    slug: string;
    syncedAt: string;
    siteGitSha: string;
  };
}

interface Props {
  /** Project slug — matches src/data/metrics/<slug>.json. */
  slug: string;
  /** The table.id within the JSON to render. */
  tableId: string;
  /** term-bar path label shown in the component header. */
  path?: string;
  /** Override empty-state copy. */
  emptyNote?: string;
}

const { slug, tableId, path, emptyNote } = Astro.props;

// Try to load the metrics JSON. If it doesn't exist, we fall through to the
// empty state. The import.meta.glob approach is used so Vite/Astro can
// statically analyze the dependency at build time.
const allMetrics = import.meta.glob<MetricsFile>('/src/data/metrics/*.json', {
  eager: true,
});

const metricsKey = `/src/data/metrics/${slug}.json`;
const metricsFile: MetricsFile | undefined = allMetrics[metricsKey];

let columns: BenchColumn[] | undefined;
let rows: Record<string, BenchCell>[] | undefined;
let caption: string | undefined;
let provenance: string | undefined;

if (metricsFile) {
  const table = metricsFile.tables.find((t) => t.id === tableId);
  if (table) {
    caption = table.caption;
    columns = table.columns.map((c) => ({
      key: c.key,
      label: c.label,
      numeric: c.numeric ?? false,
    }));
    // Map rows: cells that have a column with delta get wrapped as BenchCell objects.
    const deltaKeys = new Set(
      table.columns.filter((c) => c.delta).map((c) => c.key),
    );
    const deltaDirections = Object.fromEntries(
      table.columns
        .filter((c) => c.delta)
        .map((c) => [c.key, c.delta as 'good' | 'bad']),
    );

    rows = table.rows.map((row) => {
      const mapped: Record<string, BenchCell> = {};
      for (const [k, v] of Object.entries(row)) {
        if (deltaKeys.has(k)) {
          mapped[k] = { value: v, delta: deltaDirections[k] };
        } else {
          mapped[k] = v;
        }
      }
      return mapped;
    });

    if (metricsFile._meta) {
      provenance = `synced from ${slug} at git ${metricsFile._meta.siteGitSha} on ${metricsFile._meta.syncedAt.slice(0, 10)}`;
    }
  }
}

const resolvedPath = path ?? `bench/${slug}/${tableId}`;
---

<BenchTable
  path={resolvedPath}
  caption={caption}
  provenance={provenance}
  columns={columns}
  rows={rows}
  emptyNote={emptyNote}
/>
