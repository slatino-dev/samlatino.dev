---
/**
 * Metric — one stat cell: faint uppercase label, large mono value, optional
 * one-line detail. Designed to sit inside a StatGrid but self-contained
 * enough to stand alone.
 */
interface Props {
  label: string;
  value: string | number;
  detail?: string;
}

const { label, value, detail } = Astro.props;
---

<div class="metric">
  <dt class="metric-label">{label}</dt>
  <dd class="metric-value">
    {value}
    {detail && <span class="metric-detail">{detail}</span>}
  </dd>
</div>

<style>
  .metric {
    background-color: var(--color-surface);
    padding: 0.75rem 0.875rem 0.8rem;
  }

  .metric-label {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-faint);
  }

  .metric-value {
    margin: 0.25rem 0 0;
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    line-height: 1.2;
    color: var(--color-text);
  }

  .metric-detail {
    display: block;
    margin-top: 0.15rem;
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-text-muted);
  }
</style>
